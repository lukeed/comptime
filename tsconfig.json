{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "declaration": true,
    "exactOptionalPropertyTypes": true,
    "lib": [
      "ES2024"
    ],
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2024",
    "types": [
      "bun-types"
    ],
    "verbatimModuleSyntax": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
