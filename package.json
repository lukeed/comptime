{
  "name": "comptime",
  "version": "0.1.0",
  "description": "A Zig-inspired build-time evaluation primitive, exposed as Vite and Rolldown plugins.",
  "keywords": [
    "build-time",
    "compile-time",
    "comptime",
    "evaluation",
    "rolldown",
    "rollup",
    "vite",
    "zig"
  ],
  "license": "MIT",
  "author": {
    "name": "Luke Edwards",
    "email": "luke.edwards05@gmail.com",
    "url": "https://lukeed.com"
  },
  "repository": "lukeed/comptime",
  "workspaces": [
    "examples/*"
  ],
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./rolldown": {
      "types": "./dist/rolldown.d.ts",
      "import": "./dist/rolldown.js"
    }
  },
  "scripts": {
    "build": "bun run build:js && bun run build:types",
    "build:js": "bun build src/runtime.ts src/vite.ts src/rolldown.ts --outdir dist --target node --format esm --external devalue --external magic-string --external rolldown --external rolldown/experimental --external rolldown/utils --external vite --external vite/module-runner",
    "build:types": "tsc -p tsconfig.build.json",
    "types": "tsc --noEmit",
    "fmt": "oxfmt",
    "prepack": "bun run build",
    "test": "bun test src/*.test.ts"
  },
  "dependencies": {
    "devalue": "^5.5.0",
    "magic-string": "^0.30.19"
  },
  "devDependencies": {
    "bun-types": "1.3.13",
    "oxfmt": "^0.48.0",
    "rolldown": "^1.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0"
  },
  "peerDependencies": {
    "rolldown": "^1.0.0",
    "vite": "^6 || ^7 || ^8"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  }
}
